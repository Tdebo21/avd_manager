{
  "name": "avd_manager",
  "version": "1.0.12",
  "description": "A Dart CLI tool for AVD management",
  "scripts": {
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch",
    "release:dry-run:standard": "standard-version --dry-run",
    "release:dry-run:npm": "npm publish --dry-run",
    "release:prepare": "npx standard-version --release-as patch",
    "release:verify": "git log --oneline -5 && git tag -l | tail -5",
    "release:push": "git push --follow-tags origin main",
    "release:publish": "npm publish"
  },
  "devDependencies": {
    "conventional-changelog": "^7.2.0",
    "conventional-changelog-angular": "^8.3.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "standard-version": "^9.5.0"
  }
}
